    <link href="http://example.com/2023/08/05/%E5%8F%A3%E8%AF%AD%EF%BC%88%E6%B5%8B%E8%AF%95%E6%96%87%E6%A1%A3%EF%BC%89-1/"/>
    <id>http://example.com/2023/08/05/%E5%8F%A3%E8%AF%AD%EF%BC%88%E6%B5%8B%E8%AF%95%E6%96%87%E6%A1%A3%EF%BC%89-1/</id>
    <published>2023-08-05T12:15:25.000Z</published>
